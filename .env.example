# No environment variables are required for the current frontend.
#
# For browser-exposed values in a Vite app, use the VITE_ prefix:
# VITE_PUBLIC_API_URL=https://api.example.com
#
# For Expo web values, prefer EXPO_PUBLIC_ variables:
# EXPO_PUBLIC_API_URL=https://api.example.com
#
# Never commit real API keys, secrets, or tokens.
